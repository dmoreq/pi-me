  "dependencies": {



    "bunfig": "^0.15.9",

    "defuddle": "^0.18.1",
    "jsonc-parser": "^3.3.1",
    "linkedom": "^0.18.12",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",

    "pi-docparser": "^1.1.1",


    "pi-link": "^0.1.11",
    "pi-markdown-preview": "^0.9.7",


    "pi-dialog": "github:dmoreq/pi-dialog",
    "pi-web-providers": "^3.0.0",
    "shell-quote": "^1.8.3",
    "wreq-js": "^2.3.0",
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "scripts": {
    "test": "tsx --test \"shared/**/*.test.ts\" \"foundation/**/*.test.ts\" \"session-lifecycle/**/*.test.ts\" \"core-tools/**/*.test.ts\" \"content-tools/**/*.test.ts\" \"authoring/**/*.test.ts\""
  }
}
