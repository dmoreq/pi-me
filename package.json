{
  "name": "pi-me",
  "version": "0.5.0",
  "description": "Comprehensive extension suite for the pi coding agent: SOLID-refactored with 7 merged extensions (context intelligence, planning, code quality, file intelligence, subprocess orchestration, web tools) — with profile-based loading and agent automation via telemetry",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "pi": {
    "extensions": [
      "pi-telemetry",
      "./foundation/index.ts",
      "./session-lifecycle/index.ts",
      "./core-tools/index.ts",
      "./content-tools/index.ts",
      "./authoring/index.ts",
      "pi-web-providers/dist/index.js",
      "pi-dialog"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./themes/minimal.json",
      "./themes/minimal-light.json"
    ]
  },
  "dependencies": {
    "bunfig": "^0.15.9",
    "defuddle": "^0.18.1",
    "jsonc-parser": "^3.3.1",
    "linkedom": "^0.18.12",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "pi-dialog": "github:dmoreq/pi-dialog",
    "pi-telemetry": "github:dmoreq/pi-telemetry",
    "pi-docparser": "^1.1.1",
    "pi-link": "^0.1.11",
    "pi-markdown-preview": "^0.9.7",
    "pi-web-providers": "^2.4.2",
    "shell-quote": "^1.8.3",
    "wreq-js": "^2.3.0",
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "overrides": {
    "@anthropic-ai/sdk": ">=0.92.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "scripts": {
    "test": "tsx --test \"shared/**/*.test.ts\" \"foundation/**/*.test.ts\" \"session-lifecycle/**/*.test.ts\" \"core-tools/**/*.test.ts\" \"content-tools/**/*.test.ts\" \"authoring/**/*.test.ts\""
  }
}
